{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.js"
	},
	"dependencies": {
		"@hono/trpc-server": "catalog:",
		"@ocean-dataview/trpc": "workspace:*",
		"@ocean-dataview/db": "workspace:*",
		"@ocean-dataview/env": "workspace:*",
		"@trpc/server": "catalog:",
		"dotenv": "catalog:",
		"hono": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@ocean-dataview/config": "workspace:*",
		"@types/bun": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	}
}
