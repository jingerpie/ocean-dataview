{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@hono/trpc-server": "catalog:",
    "@sparkyidea/trpc": "workspace:*",
    "@sparkyidea/db": "workspace:*",
    "@sparkyidea/env": "workspace:*",
    "@trpc/server": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@sparkyidea/config": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
