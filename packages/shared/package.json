      "default": "./src/utils/parsers/filter.ts"
    },
    "./utils/parsers/group": {
      "default": "./src/utils/parsers/group.ts"
    },
    "./utils/parsers/pagination": {
      "default": "./src/utils/parsers/pagination.ts"
    },
    "./utils/parsers/sort": {
