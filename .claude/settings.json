{
  "permissions": {
    "deny": ["Bash(git commit*)", "Bash(git add*)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun x ultracite fix"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true
  }
}
